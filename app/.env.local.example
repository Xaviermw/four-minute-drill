# Copy to .env.local and fill in to enable the global leaderboard.
# Both are the PUBLIC values from Supabase → Project Settings → API.
# (Safe to ship in the client bundle as long as table RLS is enabled.)
# Leave unset to run the app with the leaderboard disabled.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
